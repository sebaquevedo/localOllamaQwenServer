# Copy this file to .env and fill in your own values
# cp .env.example .env

# PostgreSQL
POSTGRES_DB=aidb
DB_USERNAME=your_db_user
DB_PASSWORD=your_strong_password

# JWT — generate a random secret of at least 32 characters
# Example (Linux/Mac): openssl rand -hex 32
# Example (Windows PowerShell): [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SECRET=replace_with_a_random_secret_of_at_least_32_chars
JWT_EXPIRATION=86400000

# Server
SERVER_PORT=8081

# Ollama
OLLAMA_MODEL=qwen3:1.7b
